# Password required to access /admin (the content management dashboard).
# Copy this file to .env.local and set a strong value before deploying.
ADMIN_PASSWORD=changeme123

# Vercel KV (Upstash Redis) credentials used to store editable site content.
# Run `vercel env pull .env.local` after linking a KV/Redis store to your
# Vercel project to fill these in automatically, or copy them from the
# Vercel dashboard (Storage > your store > .env.local tab).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Blob token used to store uploaded logo/favicon images.
# Run `vercel env pull .env.local` after linking a Blob store to your
# Vercel project, or copy it from the Vercel dashboard
# (Storage > your Blob store > .env.local tab).
BLOB_READ_WRITE_TOKEN=
